{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    // IPs of trusted reverse proxies (e.g. Traefik) whose X-Forwarded-For header should be
    // trusted for RemoteIpAddress (rate limiting, etc). Empty by default (local dev, direct
    // Kestrel access). Set via ReverseProxy__KnownProxies__0=<ip> env var in production.
    "KnownProxies": []
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=QuestBoard;User Id=QuestBoardUser;Password=QuestBoardUser!;Trusted_Connection=true;TrustServerCertificate=true;"
  },
  "AutoMapper": {
    "LicenseKey": "" // Set via environment variable AutoMapper__LicenseKey or user-secrets in dev
  },
  "EmailSettings": {
    "SmtpServer": "192.168.6.13",
    "SmtpPort": 25,
    "EnableSsl": false,
    "SmtpUsername": "",
    "SmtpPassword": "",
    "FromEmail": "noreply@theunschut.com",
    "FromName": "D&D Quest Board",
    "AppUrl": "https://localhost:8001",
    "ResendApiKey": ""
  }
}
