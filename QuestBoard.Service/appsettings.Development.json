{
  "EmailSettings": {
    // Skips the real SMTP send while running locally so the whole flow — Hangfire jobs,
    // rendering, flash messages — still exercises end to end. Flip to false locally
    // (or set EmailSettings__SuppressSending=false) to test against a real inbox.
    // Only loaded when ASPNETCORE_ENVIRONMENT=Development — production never sees this file.
    "SuppressSending": true
  }
}
