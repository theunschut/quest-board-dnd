@using QuestBoard.Domain.Enums
@using QuestBoard.Service.ViewModels.CharacterViewModels
@model CharactersIndexViewModel

@section Styles {
    <link href="~/css/guild-members.mobile.css" asp-append-version="true" rel="stylesheet" />
}

<a href="@Url.Action("Create")" class="btn btn-warning w-100 mb-3">
    <i class="fas fa-plus me-2"></i>Create New Character
</a>

<div class="guild-section-card mb-4">
    <div class="guild-section-heading mb-2">
        <i class="fas fa-user-circle text-success me-2"></i>My Characters
    </div>
    @if (Model.MyCharacters.Any())
    {
        @foreach (var character in Model.MyCharacters)
        {
            <div class="guild-member-row d-flex align-items-center@(character.Status == CharacterStatus.Retired ? " retired" : "")" onclick="window.location.href='@Url.Action("Details", new { id = character.Id })'">
                @if (character.ProfilePicture != null)
                {
                    <img src="@Url.Action("GetProfilePicture", new { id = character.Id })" class="guild-member-thumbnail me-3" alt="@character.Name" />
                }
                else
                {
                    <div class="guild-member-placeholder me-3"><i class="fas fa-user"></i></div>
                }
                <div class="flex-grow-1">
                    <div class="guild-member-name">@character.Name</div>
                    <div class="guild-member-class">Level @character.Level — @string.Join(" / ", character.Classes.Select(c => $"{c.Class} {c.ClassLevel}"))</div>
                    <div>
                        @if (character.Role == CharacterRole.Main)
                        {
                            <span class="badge bg-warning text-dark"><i class="fas fa-star me-1"></i>Main</span>
                        }
                        @if (character.Status == CharacterStatus.Retired)
                        {
                            <span class="badge bg-secondary">Retired</span>
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="guild-empty-state">
            <i class="fas fa-users-slash fa-2x mb-2"></i>
            <h5>No Characters Yet</h5>
            <p>Create your first character to join the guild!</p>
            <a href="@Url.Action("Create")" class="btn btn-warning"><i class="fas fa-plus me-2"></i>Create Character</a>
        </div>
    }
</div>

<div class="guild-section-card mb-4">
    <div class="guild-section-heading mb-2">
        <i class="fas fa-users text-primary me-2"></i>Guild Roster
    </div>
    @if (Model.OtherCharacters.Any())
    {
        @foreach (var character in Model.OtherCharacters)
        {
            <div class="guild-member-row d-flex align-items-center@(character.Status == CharacterStatus.Retired ? " retired" : "")" onclick="window.location.href='@Url.Action("Details", new { id = character.Id })'">
                @if (character.ProfilePicture != null)
                {
                    <img src="@Url.Action("GetProfilePicture", new { id = character.Id })" class="guild-member-thumbnail me-3" alt="@character.Name" />
                }
                else
                {
                    <div class="guild-member-placeholder me-3"><i class="fas fa-user"></i></div>
                }
                <div class="flex-grow-1">
                    <div class="guild-member-name">@character.Name</div>
                    <div class="guild-member-class">Level @character.Level — @string.Join(" / ", character.Classes.Select(c => $"{c.Class} {c.ClassLevel}"))</div>
                    <div class="guild-member-owner"><i class="fas fa-user me-1"></i>@character.OwnerName</div>
                    <div>
                        @if (character.Status == CharacterStatus.Retired)
                        {
                            <span class="badge bg-secondary">Retired</span>
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="guild-empty-state">
            <i class="fas fa-dungeon fa-2x mb-2"></i>
            <h5>No Other Characters</h5>
            <p>The guild awaits other adventurers!</p>
        </div>
    }
</div>
