@using QuestBoard.Domain.Enums
@using QuestBoard.Service.ViewModels.CharacterViewModels
@model CharacterViewModel
@{
    ViewData["Title"] = Model.Name;
    var isOwner = Model.IsOwner;
    var isRetired = Model.Status == CharacterStatus.Retired;
}

@section Styles {
    <link href="~/css/character-detail.mobile.css" asp-append-version="true" rel="stylesheet" />
}

<div class="container-fluid px-3 py-3">

    <!-- Portrait Card -->
    <div class="character-detail-card mb-3 text-center">
        @if (Model.ProfilePicture != null)
        {
            <img src="@Url.Action("GetProfilePicture", new { id = Model.Id })" alt="@Model.Name" class="character-portrait-mobile img-fluid mb-3" />
        }
        else
        {
            <div class="character-portrait-placeholder mb-3"><i class="fas fa-user fa-5x"></i></div>
        }
        <h2 class="character-name-mobile mb-1">@Model.Name</h2>
        <p class="character-info-value mb-2">Owned by @Model.OwnerName</p>
        @if (isRetired)
        {
            <span class="badge bg-secondary me-1 mb-1"><i class="fas fa-moon me-1"></i>Retired</span>
        }
        else
        {
            <span class="badge bg-success me-1 mb-1"><i class="fas fa-check-circle me-1"></i>Active</span>
        }
        @if (Model.Role == CharacterRole.Main)
        {
            <span class="badge bg-warning me-1 mb-1"><i class="fas fa-star me-1"></i>Main Character</span>
        }
    </div>

    <!-- Character Info Card -->
    <div class="character-detail-card mb-3">
        <div class="character-section-heading mb-2"><i class="fas fa-scroll me-2"></i>Character Information</div>
        <div class="character-info-row">
            <span class="form-label">Level</span>
            <span class="character-info-value">@Model.Level</span>
        </div>
        <div class="character-info-row">
            <span class="form-label">Character Sheet</span>
            @if (!string.IsNullOrEmpty(Model.SheetLink))
            {
                <p class="mb-0"><a href="@Model.SheetLink" target="_blank" class="text-break">@Model.SheetLink <i class="fas fa-external-link-alt ms-1"></i></a></p>
            }
            else
            {
                <p class="text-muted mb-0">Not provided</p>
            }
        </div>
        <div class="character-info-row">
            <span class="form-label">Classes</span>
            @if (Model.Classes.Any())
            {
                <div class="mt-1">
                @foreach (var charClass in Model.Classes)
                {
                    <span class="badge bg-primary me-1 mb-1">@charClass.Class Level @charClass.ClassLevel</span>
                }
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No classes defined</p>
            }
        </div>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="character-info-row">
                <span class="form-label">Description</span>
                <p class="character-info-value mb-0">@Model.Description</p>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.Backstory))
        {
            <div class="character-info-row">
                <span class="form-label">Backstory</span>
                <p class="character-info-value mb-0">@Model.Backstory</p>
            </div>
        }
    </div>

    <!-- Owner Actions Card -->
    @if (isOwner)
    {
        <div class="character-detail-card mb-3">
            <div class="character-section-heading mb-3"><i class="fas fa-cog me-2"></i>Owner Actions</div>
            <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-warning w-100 mb-2">
                <i class="fas fa-edit me-2"></i>Edit Character
            </a>
            <form asp-action="ToggleRetirement" method="post" class="mb-2">
                <input type="hidden" name="id" value="@Model.Id" />
                @if (isRetired)
                {
                    <button type="submit" class="btn btn-success w-100">
                        <i class="fas fa-undo me-2"></i>Reactivate Character
                    </button>
                }
                else
                {
                    <button type="submit" class="btn btn-secondary w-100">
                        <i class="fas fa-moon me-2"></i>Retire Character
                    </button>
                }
            </form>
            <form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this character? This action cannot be undone.');">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-danger w-100">
                    <i class="fas fa-trash me-2"></i>Delete Character
                </button>
            </form>
        </div>
    }

    <!-- Back Button -->
    <div class="mt-3">
        <a href="@Url.Action("Index")" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Guild Members
        </a>
    </div>

</div>
