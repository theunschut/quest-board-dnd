@{
    ViewData["Title"] = "Welcome";
}

<div class="container-fluid px-3 mt-5 text-center">
    <i class="fas fa-dice-d20 fa-4x text-warning mb-3"></i>
    <h3 class="mb-2">D&amp;D Quest Board</h3>
    <p class="text-muted mb-4">Track quests, sign up for adventures, and manage your campaigns — all in one place.</p>
    <div class="d-grid">
        <a asp-controller="Account" asp-action="Login" class="btn btn-warning btn-lg">
            <i class="fas fa-sign-in-alt me-2"></i>Log In
        </a>
    </div>
</div>
