@using QuestBoard.Service.ViewModels.QuestLogViewModels
@model EditRecapViewModel
@{
    ViewData["Title"] = $"Edit Recap: {Model.Quest.Title}";
}

@section Styles {
    <link href="~/css/quest-edit.mobile.css" asp-append-version="true" rel="stylesheet" />
}

<div class="container-fluid px-2 mt-2">

    <div class="quest-edit-card-mobile mb-3">

        <div class="mb-3">
            <h5 class="mb-0">
                <i class="fas fa-book me-2"></i>Edit Recap: @Model.Quest.Title
            </h5>
        </div>

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <form asp-action="EditRecap" asp-route-id="@Model.Id" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label for="recap" class="form-label">Write or update the session recap:</label>
                <textarea class="form-control"
                          id="recap"
                          name="recap"
                          rows="6"
                          placeholder="Describe what happened during this quest...">@Model.Recap</textarea>
                <small class="form-text">Share the story of this adventure with your players!</small>
            </div>

            <div class="d-flex gap-2 mt-3">
                <a href="@Url.Action("Details", "QuestLog", new { id = Model.Id })" class="btn btn-secondary flex-fill">
                    <i class="fas fa-times me-2"></i>Cancel
                </a>
                <button type="submit" class="btn btn-primary flex-fill">
                    <i class="fas fa-save me-2"></i>Save Recap
                </button>
            </div>

        </form>

    </div>
</div>
