@using QuestBoard.Service.ViewModels.QuestLogViewModels
@using QuestBoard.Domain.Enums
@using QuestBoard.Service.Extensions
@model QuestLogDetailsViewModel
@{
    ViewData["Title"] = $"Quest Log: {Model.Quest.Title}";
    var tokens = Antiforgery.GetAndStoreTokens(ViewContext.HttpContext);
    var boardType = (BoardType)ViewBag.BoardType;
}

@section Styles {
    <link href="~/css/quest-log-detail.mobile.css" asp-append-version="true" rel="stylesheet" />
}

<div class="container-fluid px-2 mt-2">

    <!-- Card 1: Main content -->
    <div class="quest-log-detail-main-card mb-3">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">@Model.Quest.Title</h5>
            @if (boardType != BoardType.Campaign)
            {
                <span class="badge bg-secondary">
                    <i class="fas fa-dice-d20 me-1"></i>CR @Model.Quest.ChallengeRating
                </span>
            }
        </div>

        <!-- Quest Information -->
        <div class="mb-3">
            <h6><i class="fas fa-info-circle me-2"></i>Quest Information</h6>
            <p class="mb-1"><strong>Dungeon Master:</strong> @Model.Quest.DungeonMaster?.Name</p>
            @if (boardType != BoardType.Campaign)
            {
                <p class="mb-1"><strong>Challenge Rating:</strong> @Model.Quest.ChallengeRating</p>
            }
            <p class="mb-1"><strong>Completed On:</strong> @((Model.Quest.FinalizedDate ?? Model.Quest.ClosedDate)?.ToString("MMMM dd, yyyy 'at' h:mm tt"))</p>
            <p class="mb-0"><strong>Created:</strong> @Model.Quest.CreatedAt.ToString("MMMM dd, yyyy")</p>
        </div>
        <hr />

        <!-- Original Quest Description -->
        <div class="mb-3">
            <h6><i class="fas fa-scroll me-2"></i>Original Quest Description</h6>
            <div class="recap-display-box">
                @Model.Quest.Description
            </div>
        </div>
        <hr />

        @if (!string.IsNullOrWhiteSpace(Model.Quest.Rewards))
        {
            <!-- Rewards -->
            <div class="mb-3">
                <h6><i class="fas fa-coins text-warning me-2"></i>Rewards</h6>
                <div class="quest-description-box">@Html.Markdown(Model.Quest.Rewards)</div>
            </div>
            <hr />
        }

        @{
            var selectedPlayers = Model.Quest.PlayerSignups.Where(ps => ps.IsSelected).OrderBy(ps => ps.SignupTime).ToList();
        }
        @if (boardType != BoardType.Campaign)
        {
            <!-- Adventurers -->
            <div class="mb-3">
                <h6><i class="fas fa-users me-2"></i>Adventurers</h6>
                @if (selectedPlayers.Any())
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var player in selectedPlayers)
                        {
                            <li class="mb-2">
                                <strong>@player.Player.Name</strong>
                                @if (player.Character != null)
                                {
                                    <span>
                                        (<img src="@Url.Action("GetCroppedPicture", "Characters", new { id = player.Character.Id })"
                                              alt="@player.Character.Name"
                                              class="character-mini-avatar"
                                              onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-flex';" />
                                        <span class="character-mini-avatar-placeholder" style="display: none;">
                                            <i class="fas fa-user"></i>
                                        </span>
                                        @player.Character.Name)
                                    </span>
                                }
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="mb-0 text-muted">No adventurers participated in this quest.</p>
                }
            </div>
            <hr />
        }

        <!-- Session Recap -->
        <div class="mb-0">
            <h6><i class="fas fa-book me-2"></i>Session Recap</h6>

            @if (!string.IsNullOrWhiteSpace(Model.Quest.Recap))
            {
                <div class="recap-display-box">
                    @Html.Markdown(Model.Quest.Recap)
                </div>
            }
            else
            {
                <p class="mb-0 text-muted">No recap has been written for this quest yet.</p>
            }

            @if ((bool)ViewBag.CanEditRecap)
            {
                <a href="@Url.Action("EditRecap", "QuestLog", new { id = Model.Quest.Id })" class="btn btn-primary w-100 mt-3">
                    @if (!string.IsNullOrWhiteSpace(Model.Quest.Recap))
                    {
                        <i class="fas fa-edit me-2"></i>@:Edit Recap
                    }
                    else
                    {
                        <i class="fas fa-plus me-2"></i>@:Add Recap
                    }
                </a>
            }
        </div>

    </div>

    <!-- Card 2: Quick Actions -->
    <div class="quest-log-detail-actions-card mb-3">
        <h6 class="mb-3"><i class="fas fa-bolt text-warning me-2"></i>Quick Actions</h6>
        <a href="@Url.Action("Index", "QuestLog")" class="btn btn-secondary w-100 mb-2">
            <i class="fas fa-arrow-left me-2"></i>Back to Quest Log
        </a>
        @if ((bool)ViewBag.CanManageQuest)
        {
            <a href="@Url.Action("Manage", "Quest", new { id = Model.Quest.Id })" class="btn btn-info w-100">
                <i class="fas fa-cog me-2"></i>Manage Quest
            </a>
        }
    </div>
    @if (boardType != BoardType.Campaign)
    {
        <!-- Card 3: Quest Statistics -->
        <div class="quest-log-detail-stats-card mb-3">
            <h6 class="mb-3"><i class="fas fa-chart-bar text-warning me-2"></i>Quest Statistics</h6>
            <p class="mb-1"><strong>Total Signups:</strong> @Model.Quest.PlayerSignups.Count</p>
            <p class="mb-1"><strong>Participants:</strong> @selectedPlayers.Count / @Model.Quest.TotalPlayerCount</p>
            <p class="mb-1">
                <strong>Building Access:</strong>
                @{
                    var dmHasKey = Model.Quest.DungeonMaster?.HasKey == true;
                    var playersHaveKey = Model.Quest.PlayerSignups?.Any(ps => ps.Player.HasKey == true) == true;
                    var anyoneHasKey = dmHasKey || playersHaveKey;
                }
                <span class="badge @(anyoneHasKey ? "bg-success" : "bg-danger")">
                    @if (anyoneHasKey)
                    {
                        <i class="fas fa-key me-1"></i>@:Available
                    }
                    else
                    {
                        <i class="fas fa-lock me-1"></i>@:No Key
                    }
                </span>
            </p>
            <p class="mb-0">
                <strong>Status:</strong>
                <span class="badge bg-dark">
                    <i class="fas fa-flag-checkered me-1"></i>Completed
                </span>
            </p>
        </div>
    }
</div>
