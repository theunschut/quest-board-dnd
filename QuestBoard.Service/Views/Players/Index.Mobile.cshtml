@using QuestBoard.Domain.Interfaces
@using QuestBoard.Service.ViewModels.PlayersViewModels
@model PlayersIndexViewModel
@{
    ViewData["Title"] = "Players";
}

@section Styles {
    <link href="~/css/players.mobile.css" asp-append-version="true" rel="stylesheet" />
}

<div class="container-fluid px-3 py-3">

    <div class="players-section-card mb-4">
        <div class="players-section-heading mb-2">
            <i class="fas fa-crown text-warning me-2"></i>Dungeon Masters
        </div>

        @if (Model.DungeonMasters.Any())
        {
            @foreach (var dm in Model.DungeonMasters)
            {
                <div class="players-row"
                     onclick="window.location.href='@Url.Action("Profile", "DungeonMaster", new { id = dm.Id })'">
                    <span class="players-name">@dm.Name</span>
                    <i class="fas fa-chevron-right ms-auto" style="color: rgba(244,228,188,0.5);"></i>
                </div>
            }
        }
        else
        {
            <div class="players-empty-state">
                <i class="fas fa-dragon fa-2x mb-2"></i>
                <h5>No Dungeon Masters Found</h5>
                <p>No dungeon masters are registered yet. Brave souls may register as new quest leaders.</p>
            </div>
        }
    </div>

    <div class="players-section-card mb-3">
        <div class="players-section-heading mb-2">
            <i class="fas fa-users text-primary me-2"></i>Registered Players
        </div>

        @if (Model.Players.Any())
        {
            @foreach (var player in Model.Players)
            {
                <div class="players-row no-link">
                    <span class="players-name">@player.Name</span>
                </div>
            }
        }
        else
        {
            <div class="players-empty-state">
                <i class="fas fa-user fa-2x mb-2"></i>
                <h5>No Players Found</h5>
                <p>No adventurers have registered yet. Players can register to join quests.</p>
            </div>
        }
    </div>

</div>
