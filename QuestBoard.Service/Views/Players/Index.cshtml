@using QuestBoard.Domain.Interfaces
@using QuestBoard.Service.ViewModels.PlayersViewModels
@model PlayersIndexViewModel
@{
    ViewData["Title"] = "Players";
}

<div class="row">
    <div class="col-md-6">
        <div class="card modern-card">
            <div class="card-header modern-card-header">
                <h2 class="mb-0">
                    <i class="fas fa-crown text-warning me-2"></i>
                    Dungeon Masters
                </h2>
            </div>
            <div class="card-body modern-card-body">
                @if (Model.DungeonMasters.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th scope="col">Name</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var dm in Model.DungeonMasters)
                                {
                                    <tr>
                                        <td>
                                            <a asp-controller="DungeonMaster" asp-action="Profile" asp-route-id="@dm.Id">@dm.Name</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-dragon fa-3x text-warning mb-3"></i>
                        <h4>No Dungeon Masters Found</h4>
                        <p class="text-muted">No dungeon masters are registered yet. Brave souls may register as new quest leaders.</p>
                    </div>
                }
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card modern-card">
            <div class="card-header modern-card-header">
                <h2 class="mb-0">
                    <i class="fas fa-users text-primary me-2"></i>
                    Registered Players
                </h2>
            </div>
            <div class="card-body modern-card-body">
                @if (Model.Players.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th scope="col">Name</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var player in Model.Players)
                                {
                                    <tr>
                                        <td>@player.Name</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-user fa-3x text-warning mb-3"></i>
                        <h4>No Players Found</h4>
                        <p class="text-muted">No adventurers have registered yet. Players can register to join quests.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
