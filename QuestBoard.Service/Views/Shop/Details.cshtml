@using QuestBoard.Service.ViewModels.ShopViewModels
@using QuestBoard.Domain.Enums
@model ShopItemViewModel
@{
    ViewData["Title"] = Model.Name + " - Shop Details";
    var isModal = ViewBag.IsModal == true;
}

@if (isModal)
{
    <!-- Modal Content - No main card wrapper -->
    <div class="item-details-content">
        <!-- Modal header -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="mb-0">@Model.Name</h2>
            <span class="badge bg-primary fs-6">
                <i class="fas fa-tag me-1"></i>
                @Model.Type
            </span>
        </div>
        
        @await Html.PartialAsync("_ShopItemDetailsContent", Model)
    </div>
}
else
{
    <!-- Full Page Content - With main card wrapper -->
    <div class="item-details-content">
        <div class="card modern-card">
            <div class="card-header modern-card-header d-flex justify-content-between align-items-center">
                <h1 class="mb-0">@Model.Name</h1>
                <span class="badge bg-primary fs-6">
                    <i class="fas fa-tag me-1"></i>
                    @Model.Type
                </span>
            </div>
            <div class="card-body modern-card-body">
                @await Html.PartialAsync("_ShopItemDetailsContent", Model)
            </div>
        </div>
    </div>

    <!-- Full page view navigation -->
    <div class="mt-4">
        <a href="/Shop" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Shop
        </a>
    </div>
}
