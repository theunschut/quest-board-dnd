@using QuestBoard.Domain.Interfaces
@using QuestBoard.Service.ViewModels.QuestViewModels
@using QuestBoard.Service.ViewModels.Shared
@model FollowUpQuestViewModel
@{
    ViewData["Title"] = "Create Follow-Up Quest";
}

@section Styles {
    <link href="~/css/quest-followup.mobile.css" asp-append-version="true" rel="stylesheet" />
}

<div class="container-fluid px-2 mt-2">
    <!-- Main form card -->
    <div class="quest-followup-card-mobile mb-3">

        <div class="mb-3">
            <h5 class="mb-0">
                <i class="fas fa-scroll text-warning me-2"></i>Create Follow-Up Quest
            </h5>
        </div>

        <div class="alert alert-info mb-3">
            <i class="fas fa-info-circle me-2"></i>
            This form is pre-filled from the original quest. Update the title, add at least one date, and save to create the follow-up.
        </div>

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <form asp-action="CreateFollowUp" asp-route-id="@Model.OriginalQuestId" method="post">
            <input type="hidden" asp-for="OriginalQuestId" />
            <input type="hidden" asp-for="DungeonMasterId" />

            <div class="mb-3">
                <label asp-for="Title" class="form-label">Quest Title <span class="text-danger">*</span></label>
                <input asp-for="Title" class="form-control" placeholder="Enter the quest title..." />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            @{ await Html.RenderPartialAsync("_MarkdownEditor", new MarkdownEditorViewModel
               {
                   FieldName = "Description",
                   Value = Model.Description,
                   Label = "Description",
                   Required = true,
                   Placeholder = "Describe the quest..."
               }); }

            @{ await Html.RenderPartialAsync("_MarkdownEditor", new MarkdownEditorViewModel
               {
                   FieldName = "Rewards",
                   Value = Model.Rewards,
                   Label = "Rewards",
                   Required = false,
                   Placeholder = "Describe the loot, gold, or other rewards for this quest..."
               }); }

            <div class="mb-3">
                <label asp-for="ChallengeRating" class="form-label">Challenge Rating <span class="text-danger">*</span></label>
                <input asp-for="ChallengeRating" type="number" class="form-control" min="1" max="20" step="1" />
                <div class="form-text">Recommended player level for this quest (1-20).</div>
                <span asp-validation-for="ChallengeRating" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TotalPlayerCount" class="form-label">Total Player Count <span class="text-danger">*</span></label>
                <input asp-for="TotalPlayerCount" inputmode="numeric" class="form-control" />
                <span asp-validation-for="TotalPlayerCount" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Proposed Dates &amp; Times <span class="text-danger">*</span></label>
                <div id="proposed-dates">
                    @for (int i = 0; i < Model.ProposedDates.Count; i++)
                    {
                        <div class="proposed-date-entry mb-2">
                            <div class="input-group">
                                <input type="datetime-local" name="ProposedDates[@i]"
                                       value="@Model.ProposedDates[i].ToString("yyyy-MM-ddTHH:mm")"
                                       class="form-control" />
                                <button type="button" class="btn btn-danger" onclick="removeDate(this)">
                                    <i class="fas fa-trash me-1"></i>Remove
                                </button>
                            </div>
                        </div>
                    }
                </div>
                <button type="button" class="btn btn-warning btn-sm mt-2" onclick="addDate()">
                    <i class="fas fa-plus me-1"></i>Add Date
                </button>
                <span asp-validation-for="ProposedDates" class="text-danger d-block mt-1"></span>
            </div>

            <div class="d-flex gap-2 mt-3">
                <a href="@Url.Action("Manage", "Quest", new { id = Model.OriginalQuestId })" class="btn btn-secondary flex-fill">
                    <i class="fas fa-arrow-left me-2"></i>Back to Quest
                </a>
                <button type="submit" class="btn btn-warning flex-fill">
                    <i class="fas fa-scroll me-2"></i>Save Follow-Up Quest
                </button>
            </div>

        </form>

    </div>

    <!-- Pre-Approved Players card — OUTSIDE the form -->
    <div class="quest-followup-players-card mb-3">
        <div class="mb-2">
            <h6 class="mb-0">
                <i class="fas fa-users text-warning me-2"></i>Pre-Approved Players
            </h6>
        </div>
        @if (ViewBag.PreApprovedPlayers != null && ((IEnumerable<dynamic>)ViewBag.PreApprovedPlayers).Any())
        {
            <ul class="list-unstyled mb-0">
                @foreach (var player in ViewBag.PreApprovedPlayers)
                {
                    <li class="mb-1"><i class="fas fa-check-circle text-success me-2"></i>@player.Name</li>
                }
            </ul>
        }
        else
        {
            <p class="mb-0 small">No players were selected on the original quest. You can add players manually after saving.</p>
        }
    </div>

</div>

@section Scripts {
    <script>
        let dateCount = @Model.ProposedDates.Count;

        function addDate() {
            const container = document.getElementById('proposed-dates');
            const entry = document.createElement('div');
            entry.className = 'proposed-date-entry mb-2';
            entry.innerHTML = `
                <div class="input-group">
                    <input type="datetime-local" name="ProposedDates[${dateCount}]" class="form-control" />
                    <button type="button" class="btn btn-outline-danger" onclick="removeDate(this)">
                        <i class="fas fa-times"></i>
                    </button>
                </div>`;
            container.appendChild(entry);

            // Pre-fill new input: last filled date + 1 day at 18:00, or today at 18:00
            const newInput = entry.querySelector('input[type="datetime-local"]');
            const allInputs = container.querySelectorAll('input[type="datetime-local"]');
            // allInputs includes the new one; check second-to-last and earlier for a prior value
            let baseDate = null;
            for (let i = allInputs.length - 2; i >= 0; i--) {
                if (allInputs[i].value) {
                    baseDate = new Date(allInputs[i].value);
                    break;
                }
            }
            if (baseDate && !isNaN(baseDate.getTime())) {
                baseDate.setDate(baseDate.getDate() + 1);
                baseDate.setHours(18, 0, 0, 0);
            } else {
                baseDate = new Date();
                baseDate.setHours(18, 0, 0, 0);
            }
            const year = baseDate.getFullYear();
            const month = String(baseDate.getMonth() + 1).padStart(2, '0');
            const day = String(baseDate.getDate()).padStart(2, '0');
            const hours = String(baseDate.getHours()).padStart(2, '0');
            const minutes = String(baseDate.getMinutes()).padStart(2, '0');
            newInput.value = `${year}-${month}-${day}T${hours}:${minutes}`;

            dateCount++;
        }

        function removeDate(button) {
            button.closest('.proposed-date-entry').remove();
            renumberDates();
        }

        function renumberDates() {
            const entries = document.querySelectorAll('#proposed-dates .proposed-date-entry input[type="datetime-local"]');
            entries.forEach((input, i) => {
                input.name = `ProposedDates[${i}]`;
            });
            dateCount = entries.length;
        }

        document.addEventListener('DOMContentLoaded', function () {
            const container = document.getElementById('proposed-dates');
            if (container && container.querySelectorAll('.proposed-date-entry').length === 0) {
                addDate();
            }
        });
    </script>
    @{ await Html.RenderPartialAsync("_QuestFormScripts"); }
}
