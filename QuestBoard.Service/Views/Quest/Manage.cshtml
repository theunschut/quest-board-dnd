@using QuestBoard.Domain.Enums
@using QuestBoard.Domain.Interfaces
@using QuestBoard.Domain.Models.QuestBoard
@model Quest
@{
    ViewData["Title"] = $"Manage Quest: {Model.Title}";
    var tokens = Antiforgery.GetAndStoreTokens(ViewContext.HttpContext);
    var boardType = (BoardType)ViewBag.BoardType;
}


@if (!(bool)ViewBag.IsAuthorized)
{
    <div class="alert alert-danger">
        <h5>Access Denied</h5>
        <p>You are not authorized to manage this quest. Only the quest's Dungeon Master can access this page.</p>
        <a href="@Url.Action("Details", "Quest", new { id = Model.Id })" class="btn btn-secondary">Back to Quest Details</a>
    </div>
}
else
{
    <div class="row">
        <div class="col-md-8">
            <div class="card modern-card">
                <div class="card-header modern-card-header d-flex justify-content-between align-items-center">
                    <h2 class="mb-0">@ViewData["Title"]</h2>
                    @if (boardType != BoardType.Campaign)
                    {
                        <span class="badge cr-badge fs-6">
                            <i class="fas fa-dice-d20 me-1"></i>
                            CR @Model.ChallengeRating
                        </span>
                    }
                </div>
                <div class="card-body modern-card-body">
                    @if (TempData["Success"] != null)
                    {
                        <form asp-action="SendReminder" asp-route-id="@Model.Id" method="post" class="mb-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="forceResend" value="true" />
                            <button type="submit" class="btn btn-sm btn-outline-warning">
                                <i class="fas fa-redo me-1"></i>Send again (bypasses duplicate check)
                            </button>
                        </form>
                    }

                    @if (boardType != BoardType.Campaign)
                    {
                    @if (Model.IsFinalized)
                    {
                        <h6>Selected Date:</h6>

                        var finalizedDate = Model.ProposedDates!.FirstOrDefault(pd => pd.Date.Date == Model.FinalizedDate?.Date);
                        if (finalizedDate != null)
                        {
                            var yesVotes = finalizedDate.PlayerVotes.Where(v => v.Vote == VoteType.Yes).ToList();
                            var maybeVotes = finalizedDate.PlayerVotes.Where(v => v.Vote == VoteType.Maybe).ToList();
                            var noVotes = finalizedDate.PlayerVotes.Where(v => v.Vote == VoteType.No).ToList();
                        
                            <div class="date-option border-success">
                                <div class="mb-2">
                                    <strong>@finalizedDate.Date.ToString("dddd, MMMM dd, yyyy 'at' h:mm tt")</strong>
                                    <span class="badge bg-success ms-2">Finalized</span>
                                </div>

                                <div class="mt-2">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <small class="text-success"><strong>Yes (@yesVotes.Count):</strong></small>
                                            <ul class="list-unstyled small">
                                                @foreach (var vote in yesVotes.OrderBy(v => v.PlayerSignup?.SignupTime))
                                                {
                                                    <li>@vote.PlayerSignup?.Player.Name</li>
                                                }
                                            </ul>
                                        </div>
                                        <div class="col-md-4">
                                            <small class="text-warning"><strong>Maybe (@maybeVotes.Count):</strong></small>
                                            <ul class="list-unstyled small">
                                                @foreach (var vote in maybeVotes.OrderBy(v => v.PlayerSignup?.SignupTime))
                                                {
                                                    <li>@vote.PlayerSignup?.Player.Name</li>
                                                }
                                            </ul>
                                        </div>
                                        <div class="col-md-4">
                                            <small class="text-danger"><strong>No (@noVotes.Count):</strong></small>
                                            <ul class="list-unstyled small">
                                                @foreach (var vote in noVotes.OrderBy(v => v.PlayerSignup?.SignupTime))
                                                {
                                                    <li>@vote.PlayerSignup?.Player.Name</li>
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        @if (!Model.ProposedDates?.Any() == true)
                        {
                            <div class="alert alert-warning">
                                <h5><i class="fas fa-exclamation-triangle me-2"></i>No Proposed Dates</h5>
                                <p>This quest doesn't have any proposed dates yet. Please edit the quest to add some dates before you can finalize it.</p>
                                <div class="mt-3">
                                    <a href="@Url.Action("Edit", "Quest", new { id = Model.Id })" class="btn btn-primary">
                                        <i class="fas fa-edit me-1"></i>Edit Quest
                                    </a>
                                    <a href="#" class="btn btn-danger ms-2" onclick="deleteQuest(@Model.Id)">
                                        <i class="fas fa-trash me-1"></i>Delete Quest
                                    </a>
                                </div>
                            </div>
                        }
                        else
                        {
                            <form asp-action="Finalize" asp-route-id="@Model.Id" method="post">
                                <h6>Proposed Dates & Voting Results:</h6>
                                @{
                                    var maxYesVotes = Model.ProposedDates!.Max(pd => pd.PlayerVotes.Count(v => v.Vote == VoteType.Yes));
                                    var hasMultipleDatesWithSameVotes = Model.ProposedDates?.Count(pd => pd.PlayerVotes.Count(v => v.Vote == VoteType.Yes) == maxYesVotes) > 1;
                                    var orderedDates = Model.ProposedDates?.OrderBy(pd => pd.Date).ToList();
                                }
                                @foreach (var date in orderedDates ?? [])
                                {
                                    var yesVotes = date.PlayerVotes.Where(v => v.Vote == VoteType.Yes).ToList();
                                    var maybeVotes = date.PlayerVotes.Where(v => v.Vote == VoteType.Maybe).ToList();
                                    var noVotes = date.PlayerVotes.Where(v => v.Vote == VoteType.No).ToList();
                                    var isRecommended = !hasMultipleDatesWithSameVotes && yesVotes.Count == maxYesVotes;

                                    <div class="date-option manage-date-option @(isRecommended ? "border-success" : "")"
                                         data-date-id="@date.Id"
                                         data-yes-votes="@string.Join(",", yesVotes.Select(v => v.PlayerSignup?.Id.ToString()).Where(id => !string.IsNullOrEmpty(id)))"
                                         data-maybe-votes="@string.Join(",", maybeVotes.Select(v => v.PlayerSignup?.Id.ToString()).Where(id => !string.IsNullOrEmpty(id)))"
                                         data-no-votes="@string.Join(",", noVotes.Select(v => v.PlayerSignup?.Id.ToString()).Where(id => !string.IsNullOrEmpty(id)))">
                                        <div class="form-check">
                                            <input class="form-check-input date-selector" type="radio" name="SelectedDateId" value="@date.Id"
                                                   id="date_@date.Id" @(isRecommended ? "checked" : "") />
                                            <label class="form-check-label" for="date_@date.Id">
                                                <strong>@date.Date.ToString("dddd, MMMM dd, yyyy 'at' h:mm tt")</strong>
                                                @if (isRecommended)
                                                {
                                                    <span class="badge bg-success ms-2">Recommended</span>
                                                }
                                            </label>
                                        </div>

                                        <div class="mt-2">
                                            <div class="row">
                                                <div class="col-md-4">
                                                    <small class="text-success"><strong>Yes (@yesVotes.Count):</strong></small>
                                                    <ul class="list-unstyled small">
                                                        @foreach (var vote in yesVotes.OrderBy(v => v.PlayerSignup?.SignupTime))
                                                        {
                                                            <li>@vote.PlayerSignup?.Player.Name</li>
                                                        }
                                                    </ul>
                                                </div>
                                                <div class="col-md-4">
                                                    <small class="text-warning"><strong>Maybe (@maybeVotes.Count):</strong></small>
                                                    <ul class="list-unstyled small">
                                                        @foreach (var vote in maybeVotes.OrderBy(v => v.PlayerSignup?.SignupTime))
                                                        {
                                                            <li>@vote.PlayerSignup?.Player.Name</li>
                                                        }
                                                    </ul>
                                                </div>
                                                <div class="col-md-4">
                                                    <small class="text-danger"><strong>No (@noVotes.Count):</strong></small>
                                                    <ul class="list-unstyled small">
                                                        @foreach (var vote in noVotes.OrderBy(v => v.PlayerSignup?.SignupTime))
                                                        {
                                                            <li>@vote.PlayerSignup?.Player.Name</li>
                                                        }
                                                    </ul>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }

                                <hr>

                            <h6>Player Selection:</h6>
                            <p class="text-muted">Select up to @Model.TotalPlayerCount players for this quest.</p>

                            @{
                                ProposedDate? dateForPlayerSelection = null;
                                List<PlayerSignup?> availablePlayers = new List<PlayerSignup?>();

                                if (Model.ProposedDates?.Any() == true)
                                {
                                    dateForPlayerSelection = hasMultipleDatesWithSameVotes ?
                                        orderedDates?.First() :
                                        orderedDates?.FirstOrDefault(pd => pd.PlayerVotes.Count(v => v.Vote == VoteType.Yes) == maxYesVotes);

                                    if (dateForPlayerSelection != null)
                                    {
                                        availablePlayers = dateForPlayerSelection.PlayerVotes
                                            .Where(v => v.Vote == VoteType.Yes)
                                            .Select(v => v.PlayerSignup)
                                            .OrderBy(ps => ps?.SignupTime)
                                            .ToList();
                                    }
                                }

                                // Group signups by role
                                var playerSignups = Model.PlayerSignups
                                    .Where(ps => ps.Role == SignupRole.Player)
                                    .OrderBy(ps => ps.SignupTime)
                                    .ToList();
                                var assistantDMs = Model.PlayerSignups
                                    .Where(ps => ps.Role == SignupRole.AssistantDM)
                                    .OrderBy(ps => ps.SignupTime)
                                    .ToList();
                                var spectators = Model.PlayerSignups
                                    .Where(ps => ps.Role == SignupRole.Spectator)
                                    .OrderBy(ps => ps.SignupTime)
                                    .ToList();
                            }

                            <div id="player-selection">
                                @* Players Section *@
                                @if (playerSignups.Any())
                                {
                                    <div class="mb-3">
                                        <h6 class="text-primary">
                                            <i class="fas fa-users me-2"></i>
                                            Players (Select up to @Model.TotalPlayerCount)
                                        </h6>
                                        @for (int i = 0; i < playerSignups.Count; i++)
                                        {
                                            var player = playerSignups[i];
                                            var isInTopPlayers = i < Model.TotalPlayerCount && availablePlayers.Contains(player);

                                            <div class="form-check player-item d-flex justify-content-between align-items-center" data-player-id="@player.Id" data-role="player">
                                                <div class="flex-grow-1">
                                                    <input class="form-check-input player-checkbox" type="checkbox" name="SelectedPlayerIds"
                                                           value="@player.Id" id="player_@player.Id"
                                                           @(isInTopPlayers ? "checked" : "") />
                                                    <label class="form-check-label" for="player_@player.Id">
                                                        @player.Player.Name
                                                        <small class="text-muted">
                                                            (Signed up: @player.SignupTime.ToString("MMM dd, h:mm tt"))
                                                            <span class="availability-status">
                                                                @if (availablePlayers.Contains(player))
                                                                {
                                                                    <span class="text-success">- Available for recommended date</span>
                                                                }
                                                            </span>
                                                        </small>
                                                    </label>
                                                </div>
                                                @if ((bool)ViewBag.IsAdmin)
                                                {
                                                    <button type="button" class="btn btn-danger btn-sm ms-2" onclick="removePlayerSignup(@player.Id, '@player.Player.Name')" title="Remove player">
                                                        <i class="fas fa-times"></i>
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </div>
                                }

                                @* Assistant DMs Section *@
                                @if (assistantDMs.Any())
                                {
                                    <div class="mb-3">
                                        <h6 class="text-success">
                                            <i class="fas fa-user-shield me-2"></i>
                                            Assistant DMs (Pre-selected, uncheck to exclude)
                                        </h6>
                                        <div class="alert alert-info small">
                                            Assistant DMs are pre-selected by default. Uncheck to exclude them from the quest.
                                        </div>
                                        @foreach (var assistant in assistantDMs)
                                        {
                                            var isAvailable = availablePlayers.Contains(assistant);
                                            <div class="form-check player-item d-flex justify-content-between align-items-center" data-player-id="@assistant.Id" data-role="assistant">
                                                <div class="flex-grow-1">
                                                    <input class="form-check-input assistant-checkbox" type="checkbox" name="SelectedPlayerIds"
                                                           value="@assistant.Id" id="assistant_@assistant.Id"
                                                           checked />
                                                    <label class="form-check-label" for="assistant_@assistant.Id">
                                                        @assistant.Player.Name
                                                        <small class="text-muted">
                                                            (Signed up: @assistant.SignupTime.ToString("MMM dd, h:mm tt"))
                                                            @if (isAvailable)
                                                            {
                                                                <span class="text-success">- Available</span>
                                                            }
                                                        </small>
                                                    </label>
                                                </div>
                                                @if ((bool)ViewBag.IsAdmin)
                                                {
                                                    <button type="button" class="btn btn-danger btn-sm ms-2" onclick="removePlayerSignup(@assistant.Id, '@assistant.Player.Name')" title="Remove player">
                                                        <i class="fas fa-times"></i>
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </div>
                                }

                                @* Spectators Section *@
                                @if (spectators.Any())
                                {
                                    <div class="mb-3">
                                        <h6 class="text-info">
                                            <i class="fas fa-eye me-2"></i>
                                            Spectators (Auto-approved)
                                        </h6>
                                        <div class="alert alert-success small">
                                            Spectators are automatically approved and do not require selection.
                                        </div>
                                        @foreach (var spectator in spectators)
                                        {
                                            <div class="player-item text-muted d-flex justify-content-between align-items-center">
                                                <div class="flex-grow-1">
                                                    <i class="fas fa-check-circle text-success me-2"></i>
                                                    @spectator.Player.Name
                                                    <small>(Signed up: @spectator.SignupTime.ToString("MMM dd, h:mm tt"))</small>
                                                </div>
                                                @if ((bool)ViewBag.IsAdmin)
                                                {
                                                    <button type="button" class="btn btn-danger btn-sm ms-2" onclick="removePlayerSignup(@spectator.Id, '@spectator.Player.Name')" title="Remove spectator">
                                                        <i class="fas fa-times"></i>
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            <hr>

                                <div class="d-flex justify-content-between">
                                    <div>
                                        <button type="submit" class="btn btn-success">Finalize Quest</button>
                                        <a href="@Url.Action("Edit", "Quest", new { id = Model.Id })" class="btn btn-primary ms-2">
                                            <i class="fas fa-edit me-1"></i>Edit Quest
                                        </a>
                                        <a href="#" class="btn btn-danger ms-2" onclick="deleteQuest(@Model.Id)">
                                            <i class="fas fa-trash me-1"></i>Delete
                                        </a>
                                    </div>
                                    <button type="button" class="btn btn-secondary" onclick="window.location.reload()">Refresh Data</button>
                                </div>
                            </form>
                        }
                    }

                    @if (Model.IsFinalized)
                    {
                        <hr>
                        var selectedPlayers = Model.PlayerSignups
                            .Where(ps => ps.IsSelected && ps.Role == SignupRole.Player)
                            .OrderBy(ps => ps.SignupTime)
                            .ToList();
                        var selectedAssistants = Model.PlayerSignups
                            .Where(ps => ps.IsSelected && ps.Role == SignupRole.AssistantDM)
                            .OrderBy(ps => ps.SignupTime)
                            .ToList();
                        var selectedSpectators = Model.PlayerSignups
                            .Where(ps => ps.IsSelected && ps.Role == SignupRole.Spectator)
                            .OrderBy(ps => ps.SignupTime)
                            .ToList();

                        var allSelectedParticipants = new List<PlayerSignup>();
                        allSelectedParticipants.AddRange(selectedPlayers);
                        allSelectedParticipants.AddRange(selectedAssistants);
                        allSelectedParticipants.AddRange(selectedSpectators);

                        @if (allSelectedParticipants.Any())
                        {
                            var finalizedProposedDateManage = Model.ProposedDates
                                ?.FirstOrDefault(pd => pd.Date == Model.FinalizedDate);

                            <h6>Selected Participants:</h6>
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>Player Name</th>
                                            <th>Character</th>
                                            <th>Role</th>
                                            <th>Vote</th>
                                            <th>Signup Time</th>
                                            @if ((bool)ViewBag.IsAdmin)
                                            {
                                                <th>Actions</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var participant in allSelectedParticipants)
                                        {
                                            var manageParticipantVote = participant.DateVotes
                                                ?.FirstOrDefault(dv => dv.ProposedDateId == finalizedProposedDateManage?.Id)?.Vote;
                                            <tr>
                                                <td>@participant.Player.Name</td>
                                                <td>
                                                    @if (participant.Character != null)
                                                    {
                                                        <div class="d-flex align-items-center">
                                                            <img src="@Url.Action("GetProfilePicture", "GuildMembers", new { id = participant.Character.Id })"
                                                                 alt="@participant.Character.Name"
                                                                 class="character-mini-avatar me-2"
                                                                 style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover;"
                                                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-flex';" />
                                                            <span class="character-mini-avatar-placeholder me-2" style="width: 32px; height: 32px; display: none; align-items: center; justify-content: center; background-color: #6c757d; color: white; border-radius: 50%;">
                                                                <i class="fas fa-user"></i>
                                                            </span>
                                                            <span>@participant.Character.Name</span>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted fst-italic">No character</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (participant.Role == SignupRole.Player)
                                                    {
                                                        <span class="badge bg-primary">
                                                            <i class="fas fa-user me-1"></i>Player
                                                        </span>
                                                    }
                                                    else if (participant.Role == SignupRole.AssistantDM)
                                                    {
                                                        <span class="badge bg-success">
                                                            <i class="fas fa-user-shield me-1"></i>Assistant DM
                                                        </span>
                                                    }
                                                    else if (participant.Role == SignupRole.Spectator)
                                                    {
                                                        <span class="badge bg-info">
                                                            <i class="fas fa-eye me-1"></i>Spectator
                                                        </span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (participant.Role == SignupRole.Spectator)
                                                    {
                                                        <span class="badge bg-secondary">
                                                            <i class="fas fa-minus me-1"></i>N/A
                                                        </span>
                                                    }
                                                    else if (manageParticipantVote == VoteType.Yes)
                                                    {
                                                        <span class="badge bg-success">
                                                            <i class="fas fa-check me-1"></i>Yes
                                                        </span>
                                                    }
                                                    else if (manageParticipantVote == VoteType.Maybe)
                                                    {
                                                        <span class="badge bg-warning text-dark">
                                                            <i class="fas fa-question me-1"></i>Maybe
                                                        </span>
                                                    }
                                                    else if (manageParticipantVote == VoteType.No)
                                                    {
                                                        <span class="badge bg-danger">
                                                            <i class="fas fa-times me-1"></i>No
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">
                                                            <i class="fas fa-minus me-1"></i>No Vote
                                                        </span>
                                                    }
                                                </td>
                                                <td><small class="text-muted">@participant.SignupTime.ToString("MMM dd, h:mm tt")</small></td>
                                                @if ((bool)ViewBag.IsAdmin)
                                                {
                                                    <td>
                                                        <button type="button" class="btn btn-danger btn-sm" onclick="removePlayerSignup(@participant.Id, '@participant.Player.Name')" title="Remove participant">
                                                            <i class="fas fa-trash me-1"></i>Remove
                                                        </button>
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">No participants selected for this quest.</p>
                        }

                        <hr>

                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex gap-2">
                                <form asp-action="Open" method="post" style="display: inline;">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn btn-warning" onclick="return confirm('Are you sure you want to open this quest? This will reopen it for changes and reset player selections.');">Open Quest</button>
                                </form>
                                @if (Model.FollowUpQuest == null)
                                {
                                    <a href="@Url.Action("CreateFollowUp", "Quest", new { id = Model.Id })"
                                       class="btn btn-primary">
                                        <i class="fas fa-scroll me-2"></i>Create Follow-Up Quest
                                    </a>
                                }
                                <form asp-action="SendReminder" asp-route-id="@Model.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-info">
                                        <i class="fas fa-envelope me-1"></i>Send Reminder
                                    </button>
                                </form>
                            </div>
                            <button type="button" class="btn btn-secondary" onclick="window.location.reload()">Refresh Data</button>
                        </div>
                    }
                    }
                    @if (boardType == BoardType.Campaign)
                    {
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex gap-2">
                                @if (!Model.IsClosed)
                                {
                                    <form asp-action="Close" method="post" style="display: inline;">
                                        <input type="hidden" name="id" value="@Model.Id" />
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-secondary">Close Quest</button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Reopen" method="post" style="display: inline;">
                                        <input type="hidden" name="id" value="@Model.Id" />
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-warning">Reopen Quest</button>
                                    </form>
                                }
                            </div>
                            <button type="button" class="btn btn-secondary" onclick="window.location.reload()">Refresh Data</button>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card modern-card mb-3">
                <div class="card-header modern-card-header">
                    <h5>View Public Page</h5>
                </div>
                <div class="card-body modern-card-body">
                    <a href="@Url.Action("Details", "Quest", new { id = Model.Id })" class="btn btn-secondary w-100">
                        <i class="fas fa-eye me-2"></i>
                        View Public Page
                    </a>
                </div>
            </div>

            <div class="card modern-card">
                <div class="card-header modern-card-header">
                    <h5>Quest Summary</h5>
                </div>
                <div class="card-body modern-card-body">
                    <p><strong>DM:</strong> @Model.DungeonMaster?.Name</p>
                    <p>
                        <strong>Status:</strong>
                        @{
                            string statusBadge;
                            string statusIcon;
                            string statusText;
                            
                            if (Model.IsFinalized == true && Model.FinalizedDate.HasValue == true && Model.FinalizedDate.Value.Date <= DateTime.UtcNow.AddDays(-1).Date)
                            {
                                statusBadge = "bg-dark";
                                statusIcon = "fas fa-flag-checkered";
                                statusText = "Done";
                            }
                            else if (Model.IsFinalized == true)
                            {
                                statusBadge = "bg-primary";
                                statusIcon = "fas fa-check-circle";
                                statusText = "Finalized";
                            }
                            else
                            {
                                statusBadge = "bg-success";
                                statusIcon = "fas fa-clock";
                                statusText = "Open for Signups";
                            }
                        }
                        <span class="badge @statusBadge">
                            <i class="@statusIcon me-1"></i>
                            @statusText
                        </span>
                    </p>
                    <p><strong>Building Access:</strong>
                        @{
                            var dmHasKey = Model.DungeonMaster?.HasKey == true;
                            var playersHaveKey = Model.PlayerSignups?.Any(ps => ps.Player.HasKey == true) == true;
                            var anyoneHasKey = dmHasKey || playersHaveKey;
                        }
                        <span class="badge @(anyoneHasKey ? "bg-success" : "bg-danger")">
                            @if (anyoneHasKey)
                            {
                                <i class="fas fa-key me-1"></i>@:Available
                            }
                            else
                            {
                                <i class="fas fa-lock me-1"></i>@:No Key
                            }
                        </span>
                    </p>
                    <p><strong>Total Signups:</strong> @Model.PlayerSignups?.Count</p>
                    <p><strong>Target Players:</strong> @Model.TotalPlayerCount</p>
                    <p><strong>Created:</strong> @Model.CreatedAt.ToString("MMM dd, yyyy")</p>

                    @if (Model.FollowUpQuest != null)
                    {
                        <p>
                            <i class="fas fa-scroll text-warning me-2"></i>
                            <strong>Continues in:</strong>
                            <a href="@Url.Action("Details", "Quest", new { id = Model.FollowUpQuest.Id })">
                                @Model.FollowUpQuest.Title
                            </a>
                        </p>
                    }
                    @if (Model.OriginalQuest != null)
                    {
                        <p>
                            <i class="fas fa-scroll text-warning me-2"></i>
                            <strong>Continues from:</strong>
                            <a href="@Url.Action("Details", "Quest", new { id = Model.OriginalQuest.Id })">
                                @Model.OriginalQuest.Title
                            </a>
                        </p>
                    }

                    <hr>

                    <h6>Quick Stats:</h6>
                    @if (Model.ProposedDates?.Any() == true)
                    {
                        var mostPopularDate = Model.ProposedDates
                            .OrderByDescending(pd => pd.PlayerVotes.Count(v => v.Vote == VoteType.Yes))
                            .First();
                        var yesCount = mostPopularDate.PlayerVotes.Count(v => v.Vote == VoteType.Yes);
                        
                        <p>
                            <strong>Best Date:</strong>
                            <small>@mostPopularDate.Date.ToString("MMM dd, h:mm tt")</small>
                        </p>
                        <p>
                            <small class="text-success">@yesCount players available</small>
                        </p>
                    }
                    else
                    {
                        <p class="text-muted">No proposed dates yet</p>
                    }
                </div>
            </div>
        </div>
    </div>
}

<script>
    function deleteQuest(id) {
        if (confirm("Are you sure?")) {
            fetch(`/Quest/Delete/${id}`, {
                method: "DELETE",
                headers: {
                    'RequestVerificationToken': '@tokens.RequestToken'
                }
            }).then(res => {
                if (res.ok) {
                    window.location.href = window.location.origin;
                } else {
                    alert("Delete failed.");
                }
            });
        }
    }

    function removePlayerSignup(signupId, playerName) {
        if (confirm(`Are you sure you want to remove ${playerName} from this quest? This will delete their signup and all associated votes.`)) {
            fetch(`/Quest/RemovePlayerSignup/${signupId}`, {
                method: "DELETE",
                headers: {
                    'RequestVerificationToken': '@tokens.RequestToken'
                }
            }).then(async res => {
                if (res.ok) {
                    // Reload the page to show updated data
                    window.location.reload();
                } else {
                    // Log the response for debugging
                    const responseText = await res.text();
                    console.error("Response status:", res.status);
                    console.error("Response body:", responseText);
                    alert(`Failed to remove player. Status: ${res.status}. Check console for details.`);
                }
            }).catch(err => {
                console.error("Error removing player:", err);
                alert("An error occurred while removing the player.");
            });
        }
    }

    function updatePlayerAvailability() {
        const selectedDateOption = document.querySelector('.date-selector:checked');
        if (!selectedDateOption) return;

        const dateContainer = selectedDateOption.closest('.date-option');
        const yesVotes = dateContainer.dataset.yesVotes ? dateContainer.dataset.yesVotes.split(',').filter(id => id) : [];
        const maybeVotes = dateContainer.dataset.maybeVotes ? dateContainer.dataset.maybeVotes.split(',').filter(id => id) : [];
        const noVotes = dateContainer.dataset.noVotes ? dateContainer.dataset.noVotes.split(',').filter(id => id) : [];

        // Update each player item
        document.querySelectorAll('.player-item').forEach(playerItem => {
            const playerId = playerItem.dataset.playerId;
            const checkbox = playerItem.querySelector('.player-checkbox');
            const statusSpan = playerItem.querySelector('.availability-status');
            
            // Determine availability status
            let status = '';
            let shouldBeChecked = false;
            
            if (yesVotes.includes(playerId)) {
                status = '<span class="text-success">- Available (Yes)</span>';
                shouldBeChecked = true;
            } else if (maybeVotes.includes(playerId)) {
                status = '<span class="text-warning">- Maybe available</span>';
                shouldBeChecked = true; // Consider "maybe" as selected per requirements
            } else if (noVotes.includes(playerId)) {
                status = '<span class="text-danger">- Not available (No)</span>';
                shouldBeChecked = false;
            } else {
                status = '<span class="text-muted">- No vote</span>';
                shouldBeChecked = false;
            }
            
            // Update the status display
            statusSpan.innerHTML = status;
            
            // Update checkbox based on availability
            checkbox.checked = shouldBeChecked;
        });
    }

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', function() {
        updatePlayerAvailability();
        
        // Add event listeners to date radio buttons
        document.querySelectorAll('.date-selector').forEach(radio => {
            radio.addEventListener('change', updatePlayerAvailability);
        });
        
        // Add event listeners to player checkboxes for validation
        // Only count Player role checkboxes toward the limit
        document.querySelectorAll('.player-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                // Count only checkboxes whose parent has data-role="player"
                const selectedPlayerCount = Array.from(document.querySelectorAll('.player-checkbox:checked'))
                    .filter(cb => cb.closest('[data-role="player"]'))
                    .length;
                const maxPlayers = @Model.TotalPlayerCount;

                if (selectedPlayerCount > maxPlayers) {
                    this.checked = false;
                    alert('Cannot select more than ' + maxPlayers + ' players for this quest.');
                }
            });
        });
    });
</script>