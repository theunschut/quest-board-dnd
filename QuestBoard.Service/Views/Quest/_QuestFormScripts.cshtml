@using QuestBoard.Domain.Interfaces
@*
    Shared JavaScript for quest forms
    Requires: site.js (contains addProposedDate and removeProposedDate functions)
*@
@{
    var markdownTokens = Antiforgery.GetAndStoreTokens(ViewContext.HttpContext);
}

<script>
    // Form validation for quest forms
    document.addEventListener('DOMContentLoaded', function() {
        // Scoped to the quest form specifically — document.querySelector('form') would
        // instead match the navbar's Logout form, which renders earlier in the DOM on
        // every authenticated page (see _Layout.cshtml / _Layout.Mobile.cshtml).
        const form = document.querySelector('form[action*="/Quest/"]');
        if (!form) return;

        form.addEventListener('submit', function(e) {
            // No #proposed-dates container means this form doesn't manage dates at all
            // (a finalized-quest Edit, or a Campaign-board Create/Edit) — nothing to require.
            const container = document.getElementById('proposed-dates');
            if (container) {
                // Existing dates render as hidden inputs (Edit.cshtml), newly-added ones as
                // datetime-local (site.js addProposedDate) — both count toward "has a date".
                const dateInputs = container.querySelectorAll('input[type="datetime-local"], input[type="hidden"][name*="ProposedDates"]');
                let hasValidDate = false;

                dateInputs.forEach(function(input) {
                    if (input.value) {
                        hasValidDate = true;
                    }
                });

                if (!hasValidDate) {
                    e.preventDefault();
                    alert('Please provide at least one proposed date and time.');
                    return false;
                }
            }

            const submitButton = document.querySelector('button[type="submit"]');
            if (submitButton) {
                submitButton.disabled = true;
                const originalText = submitButton.textContent;
                const isEdit = originalText.includes('Update');
                submitButton.textContent = isEdit ? 'Updating Quest...' : 'Creating Quest...';
            }
        });
    });
</script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde@2.21.0/dist/easymde.min.css"
