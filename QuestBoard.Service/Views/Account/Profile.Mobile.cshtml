@using QuestBoard.Domain.Interfaces
@using QuestBoard.Service.ViewModels.AccountViewModels
@model ProfileViewModel

@section Styles {
    <link href="~/css/account.mobile.css" asp-append-version="true" rel="stylesheet" />
}

<div class="account-card-mobile mb-3">
    <h5 class="mb-3"><i class="fas fa-user-cog text-success me-2"></i>Profile</h5>

    <div class="mb-3">
        <div class="account-field-label">Name</div>
        <div class="account-field-value">@Model.User?.Name</div>
    </div>

    <div class="mb-3">
        <div class="account-field-label">Email</div>
        <div class="account-field-value">@Model.User?.Email</div>
    </div>

    <div class="mb-3">
        <div class="account-field-label">Account Type</div>
        @if ((bool?)ViewData["IsAdmin"] == true)
        {
            <span class="account-field-value"><i class="fas fa-shield-alt text-danger me-2"></i>Admin</span>
        }
        else if ((bool?)ViewData["IsDungeonMaster"] == true)
        {
            <span class="account-field-value"><i class="fas fa-crown text-warning me-2"></i>Dungeon Master &amp; Player</span>
        }
        else
        {
            <span class="account-field-value">Player</span>
        }
    </div>

    <div class="mb-3">
        <div class="account-field-label">Building Access</div>
        @if (Model.User?.HasKey == true)
        {
            <span class="account-field-value"><i class="fas fa-key text-success me-2"></i>Has building key</span>
        }
        else
        {
            <span class="account-field-value"><i class="fas fa-times text-muted me-2"></i>No building key</span>
        }
    </div>

    <hr>

    <div class="d-flex justify-content-between">
        <a asp-controller="Quest" asp-action="Index" class="btn btn-warning">
            <i class="fas fa-home me-2"></i>Back to Quest Board
        </a>
        <a asp-action="Edit" class="btn btn-primary">
            <i class="fas fa-user-edit me-2"></i>Edit Profile
        </a>
    </div>
</div>
