@using QuestBoard.Service.ViewModels.DungeonMasterViewModels
@using QuestBoard.Service.Extensions
@model DMProfileViewModel
@{
    ViewData["Title"] = $"{Model.Name} — DM Profile";
}

<div class="dm-profile-page container mt-4">
    <div class="row">
        <!-- Left column: photo, name, role label, edit button -->
        <div class="col-lg-4 mb-4">
            <div class="card modern-card">
                <div class="card-body modern-card-body text-center">
                    @if (Model.HasProfilePicture)
                    {
                        <img src="@Url.Action("GetDMProfilePicture", new { id = Model.UserId })"
                             alt="@Model.Name"
                             class="rounded-circle dm-profile-photo mb-3" />
                    }
                    else
                    {
                        <div class="dm-profile-placeholder mx-auto mb-3">
                            <i class="fas fa-user fa-5x text-muted"></i>
                        </div>
                    }

                    <h2 class="mb-1">@Model.Name</h2>
                    <p class="text-muted">
                        <i class="fas fa-crown me-1"></i>Dungeon Master
                    </p>

                    @if (Model.CanEdit)
                    {
                        <hr />
                        <a asp-action="EditProfile" asp-route-id="@Model.UserId" class="btn btn-warning w-100">
                            <i class="fas fa-edit me-2"></i>Edit Profile
                        </a>
                    }
                </div>
            </div>

            <!-- About / Bio card -->
            <div class="card modern-card mt-3">
                <div class="card-header modern-card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-scroll me-2"></i>About
                    </h5>
                </div>
                <div class="card-body modern-card-body">
                    @if (!string.IsNullOrWhiteSpace(Model.Bio))
                    {
                        @Html.Markdown(Model.Bio)
                    }
                    else
                    {
                        <p class="text-muted fst-italic">No bio provided yet.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Right column: quest history -->
        <div class="col-lg-8">
            <div class="card modern-card">
                <div class="card-header modern-card-header">
                    <h2 class="mb-0">
                        <i class="fas fa-list me-2"></i>Quest History
                    </h2>
                </div>
                <div class="card-body modern-card-body">
                    @if (Model.Quests.Any())
                    {
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Date</th>
                                    <th>Difficulty</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var quest in Model.Quests)
                                {
                                    <tr>
                                        <td>
                                            <a asp-controller="Quest" asp-action="Details" asp-route-id="@quest.Id">
                                                @quest.Title
                                            </a>
                                        </td>
                                        <td class="text-muted small">
                                            @quest.Date?.ToString("MMM dd, yyyy")
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary">CR @quest.ChallengeRating</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-dragon fa-3x text-warning mb-3"></i>
                            <h4>No Quests Yet</h4>
                            <p class="text-muted">This Dungeon Master hasn't run any quests yet.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
