@using QuestBoard.Service.ViewModels.ContactViewModels
@model ContactsIndexViewModel
@{
    ViewData["Title"] = "Contacts";
}

<div class="contacts-page">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="fas fa-address-book me-2 text-warning"></i>
            Contacts
        </h1>
        @if (Model.ViewerIsDmTier)
        {
            <div class="d-flex gap-2">
                <form asp-action="ToggleShowHidden" method="post">
                    @if (Model.ShowHidden)
                    {
                        <button type="submit" class="btn btn-secondary" aria-pressed="true">
                            <i class="fas fa-eye me-2"></i>Hide Hidden
                        </button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-outline-secondary" aria-pressed="false">
                            <i class="fas fa-eye-slash me-2"></i>Show Hidden
                        </button>
                    }
                </form>
                <a href="@Url.Action("Create")" class="btn btn-warning">
                    <i class="fas fa-plus me-2"></i>Contact
                </a>
            </div>
        }
    </div>

    <div class="card modern-card">
        <div class="card-body modern-card-body">
            @if (Model.Contacts.Any())
            {
                <div class="contact-grid">
                    @foreach (var contact in Model.Contacts)
                    {
                        <div class="contact-card">
                            <a href="@Url.Action("Details", new { id = contact.Id })" class="text-decoration-none">
                                <div class="contact-card-content">
                                    <div class="contact-image">
                                        @if (contact.ContactImage != null)
                                        {
                                            <img src="@Url.Action("GetCroppedContactImage", new { id = contact.Id })" alt="@contact.Name" />
                                        }
                                        else
                                        {
                                            <div class="contact-placeholder">
                                                <i class="fas fa-user fa-3x"></i>
                                            </div>
                                        }
                                        @if (!contact.IsRevealed)
                                        {
                                            <span class="hidden-badge">
                                                <i class="fas fa-eye-slash me-1"></i>Hidden
                                            </span>
                                        }
                                    </div>
                                    <div class="contact-info">
                                        <h5 class="contact-name">@contact.Name</h5>
                                        @if (!string.IsNullOrEmpty(contact.TownCity))
                                        {
                                            <p class="contact-town-city mb-1">
                                                <i class="fas fa-map-marker-alt me-1"></i>@contact.TownCity
                                            </p>
                                        }
                                        @if (!string.IsNullOrEmpty(contact.SubLocation))
                                        {
                                            <p class="contact-sub-location mb-0">@contact.SubLocation</p>
                                        }
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-address-book fa-3x text-muted mb-3"></i>
                    <h4>No Contacts Yet</h4>
                    <p class="text-muted">No one has added a contact yet. DMs can create the first one to start building out the world.</p>
                </div>
            }
        </div>
    </div>
</div>
