@using QuestBoard.Service.Extensions
@using QuestBoard.Service.ViewModels.ContactViewModels
@using QuestBoard.Service.ViewModels.Shared
@model ContactViewModel
@{
    ViewData["Title"] = Model.Name;
}

@section Styles {
    <link href="~/css/contact-detail.mobile.css" asp-append-version="true" rel="stylesheet" />
}

<div class="container-fluid px-3 py-3">

    <!-- Portrait Card -->
    <div class="contact-detail-card mb-3 text-center">
        @if (Model.HasContactImage)
        {
            <img src="@Url.Action("GetContactImage", new { id = Model.Id })" alt="@Model.Name" class="contact-portrait-mobile img-fluid mb-3" />
        }
        else
        {
            <div class="contact-portrait-placeholder mb-3"><i class="fas fa-user fa-5x"></i></div>
        }
        <h2 class="contact-name-mobile mb-1">@Model.Name</h2>
        @if (!string.IsNullOrEmpty(Model.TownCity))
        {
            <p class="contact-info-value mb-0"><i class="fas fa-map-marker-alt me-1"></i>@Model.TownCity</p>
        }
        @if (!string.IsNullOrEmpty(Model.SubLocation))
        {
            <p class="contact-info-value mb-2">@Model.SubLocation</p>
        }
        <div class="mb-2">
            @if (!Model.IsRevealed)
            {
                <span class="badge bg-secondary fs-6">
                    <i class="fas fa-eye-slash me-1"></i>Hidden
                </span>
            }
        </div>
    </div>

    @if (Model.CanManage)
    {
        <!-- Actions Card -->
        <div class="contact-detail-card mb-3">
            <div class="contact-section-heading mb-3"><i class="fas fa-cog me-2"></i>Actions</div>
            <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-warning w-100 mb-2">
                <i class="fas fa-pen me-2"></i>Edit Contact
            </a>
            <form asp-action="ToggleReveal" method="post" class="mb-2">
                <input type="hidden" name="id" value="@Model.Id" />
                @if (!Model.IsRevealed)
                {
                    <button type="submit" class="btn btn-success w-100">
                        <i class="fas fa-eye me-2"></i>Reveal Contact
                    </button>
                }
                else
                {
                    <button type="submit" class="btn btn-secondary w-100">
                        <i class="fas fa-eye-slash me-2"></i>Hide Contact
                    </button>
                }
            </form>
            <form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this contact? This action cannot be undone.');">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-danger w-100">
                    <i class="fas fa-trash me-2"></i>Delete Contact
                </button>
            </form>
        </div>
    }

    <!-- Description Card -->
    <div class="contact-detail-card mb-3">
        <div class="contact-section-heading mb-2"><i class="fas fa-scroll me-2"></i>Description</div>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            @Html.Markdown(Model.Description)
        }
        else
        {
            <p class="text-muted mb-0">No description provided.</p>
        }
    </div>

    <!-- Notes Card -->
    <div class="contact-detail-card mb-3">
        <div class="contact-section-heading mb-2"><i class="fas fa-comment me-2"></i>Notes</div>

        <form asp-action="AddNote" method="post">
            <input type="hidden" name="contactId" value="@Model.Id" />
            @{ await Html.RenderPartialAsync("_MarkdownEditor", new MarkdownEditorViewModel
               {
                   FieldName = "Text",
                   Value = null,
                   Label = "Add a Note",
                   Required = true,
                   Placeholder = "Add a note about this contact..."
               }); }
            <div class="d-flex justify-content-end mt-2">
                <button type="submit" class="btn btn-warning">
                    <i class="fas fa-plus me-2"></i>Add Note
                </button>
            </div>
        </form>

        <hr />

        @if (Model.Notes.Any())
        {
            @foreach (var note in Model.Notes)
            {
                <div class="note-item border rounded p-3 mb-3" data-note-id="@note.Id">
                    <small class="text-muted">
                        <i class="fas fa-user me-1"></i>@note.AuthorName
                        <i class="fas fa-clock me-1 ms-2"></i>@note.CreatedAt.ToString("MMM d, yyyy h:mm tt")
                        @if (note.UpdatedAt != null)
                        {
                            <text> (edited)</text>
                        }
                    </small>
                    <div class="mb-0 mt-2 note-view-text">@Html.Markdown(note.Text)</div>
                    <div class="note-view-actions d-flex justify-content-end gap-2 mt-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary note-edit-btn" title="Edit note">
                            <i class="fas fa-pen"></i>
                        </button>
                        <form asp-action="DeleteNote" method="post" class="d-inline" onsubmit="return confirm('Delete this note? This action cannot be undone.');">
                            <input type="hidden" name="id" value="@note.Id" />
                            <input type="hidden" name="contactId" value="@Model.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete note">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </div>

                    <form asp-action="EditNote" method="post" class="note-edit-form" style="display: none;">
                        <input type="hidden" name="id" value="@note.Id" />
                        <input type="hidden" name="contactId" value="@Model.Id" />
                        @{ await Html.RenderPartialAsync("_MarkdownEditor", new MarkdownEditorViewModel
                           {
                               FieldName = "Text",
                               ElementId = $"Text_{note.Id}",
                               Value = note.Text,
                               Label = "Edit Note",
                               Required = true
                           }); }
                        <div class="d-flex justify-content-end gap-2 mt-2">
                            <button type="button" class="btn btn-sm btn-secondary note-cancel-btn">Cancel</button>
                            <button type="submit" class="btn btn-sm btn-warning">Save</button>
                        </div>
                    </form>
                </div>
            }
        }
        else
        {
            <div class="text-center py-4">
                <i class="fas fa-comment-slash fa-2x text-muted mb-2"></i>
                <p class="text-muted mb-0">No Notes Yet</p>
                <p class="text-muted small">Be the first to jot something down about this contact.</p>
            </div>
        }
    </div>

    <!-- Back Button -->
    <div class="mt-3">
        <a href="@Url.Action("Index")" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Contacts
        </a>
    </div>

</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("~/Views/Quest/_QuestFormScripts.cshtml"); }
    <script>
        // noteId -> { instance, originalText }. Lets collapseNote revert a note's visible
        // EasyMDE content to its saved text (unsaved-text discard) and lets the click handler
        // below know whether an editor has already been created for a given note this page load.
        const noteEditors = new Map();

        function collapseNote(noteItem) {
            const noteId = noteItem.dataset.noteId;
            const entry = noteEditors.get(noteId);
            if (entry) {
                entry.instance.value(entry.originalText);
            }
            noteItem.querySelector('.note-edit-form').style.display = 'none';
            noteItem.querySelector('.note-view-text').style.display = '';
            noteItem.querySelector('.note-view-actions').style.display = '';
        }

        document.querySelectorAll('.note-item').forEach(function (noteItem) {
            const noteId = noteItem.dataset.noteId;
            const editBtn = noteItem.querySelector('.note-edit-btn');
            const cancelBtn = noteItem.querySelector('.note-cancel-btn');
            const editForm = noteItem.querySelector('.note-edit-form');
            const textarea = editForm.querySelector('.markdown-editor-textarea');

            editBtn?.addEventListener('click', function () {
                // D-03: only one note editor open at a time -- collapse (and discard unsaved
                // text in) every other currently-open note editor before opening this one.
                document.querySelectorAll('.note-item').forEach(function (other) {
                    if (other !== noteItem && other.querySelector('.note-edit-form').style.display !== 'none') {
                        collapseNote(other);
                    }
                });

                noteItem.querySelector('.note-view-text').style.display = 'none';
                noteItem.querySelector('.note-view-actions').style.display = 'none';
                editForm.style.display = 'block';

                // Lazy-init: never construct EasyMDE while the container is display:none
                // (avoids the CodeMirror hidden-container sizing bug). This textarea's
                // container is now visible from the display toggle above.
                if (!noteEditors.has(noteId)) {
                    const instance = initMarkdownEditor(textarea, window.markdownAntiforgeryToken);
                    noteEditors.set(noteId, { instance: instance, originalText: textarea.value });
                } else {
                    // Re-showing an already-constructed CodeMirror instance needs a refresh call
                    // after being unhidden, or it can render with stale/zero measurements
                    // (collapsed height, broken line wrapping) until the user interacts with it.
                    noteEditors.get(noteId).instance.codemirror.refresh();
                }
            });

            cancelBtn?.addEventListener('click', function () {
                collapseNote(noteItem);
            });
        });
    </script>
}
