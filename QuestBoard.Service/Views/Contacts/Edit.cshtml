@using QuestBoard.Service.ViewModels.ContactViewModels
@model ContactViewModel
@{
    ViewData["Title"] = $"Edit {Model.Name}";
}

<div class="contacts-page">
    <div class="card modern-card">
        <div class="card-header modern-card-header">
            <h4 class="mb-0">
                <i class="fas fa-edit me-2"></i>
                Edit @Model.Name
            </h4>
        </div>
        <div class="card-body modern-card-body">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="ContactImageFile" class="form-label">Contact Image</label>
                        @if (Model.ContactImage != null)
                        {
                            <div class="mb-2">
                                <img src="@Url.Action("GetContactImage", new { id = Model.Id })" alt="Current" class="img-thumbnail" style="max-width: 200px;" />
                            </div>
                        }
                        <input type="file" asp-for="ContactImageFile" class="form-control" accept="image/*" id="contactImageInput" />
                        <small class="form-text text-muted">Upload a new contact portrait (JPG, PNG, GIF - Max 5 MB)</small>
                        <span asp-validation-for="ContactImageFile" class="text-danger"></span>
                        <div id="fileSizeError" class="text-danger" style="display: none;"></div>
                    </div>

                    <div class="col-md-8">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Name <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="TownCity" class="form-label">Town/City</label>
                                <input asp-for="TownCity" class="form-control" />
                                <span asp-validation-for="TownCity" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="SubLocation" class="form-label">Sub-location</label>
                                <input asp-for="SubLocation" class="form-control" />
                                <span asp-validation-for="SubLocation" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3" maxlength="2000"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <hr />

                <div class="d-flex justify-content-between">
                    <a href="@Url.Action("Details", new { id = Model.Id })" class="btn btn-secondary">
                        <i class="fas fa-times me-2"></i>Cancel
                    </a>
                    <button type="submit" class="btn btn-warning">
                        <i class="fas fa-save me-2"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // File size validation
        const MAX_FILE_SIZE = 5 * 1024 * 1024; // 5 MB in bytes
        const ALLOWED_TYPES = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif'];

        document.getElementById('contactImageInput')?.addEventListener('change', function(e) {
            const file = e.target.files[0];
            const errorDiv = document.getElementById('fileSizeError');

            if (file) {
                // Check file size
                if (file.size > MAX_FILE_SIZE) {
                    const sizeMB = (file.size / 1024 / 1024).toFixed(2);
                    errorDiv.textContent = `File size (${sizeMB} MB) exceeds the maximum allowed size of 5 MB. Please choose a smaller image.`;
                    errorDiv.style.display = 'block';
                    e.target.value = ''; // Clear the input
                    return;
                }

                // Check file type
                if (!ALLOWED_TYPES.includes(file.type)) {
                    errorDiv.textContent = 'Only image files (JPG, PNG, GIF) are allowed.';
                    errorDiv.style.display = 'block';
                    e.target.value = ''; // Clear the input
                    return;
                }

                // Clear any previous errors
                errorDiv.style.display = 'none';
                errorDiv.textContent = '';
            }
        });
    </script>
}
