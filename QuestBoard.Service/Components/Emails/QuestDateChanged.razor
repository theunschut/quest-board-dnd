@using QuestBoard.Service.Components.Emails

<_EmailLayout Subject="@($"Session date changed: {QuestTitle}")" PreviewText="@($"Date Changed — {QuestTitle}")">
    <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-image:url('@(AppUrl)/images/Blanks/Blanks%20w%20Shadow/Poster6.png');background-size:cover;background-position:center top;background-color:#F4E4BC;margin:0 auto;">
        <tr>
            <td style="height:800px;overflow:hidden;">
                <table width="100%" height="100%" border="0" cellpadding="0" cellspacing="0">

                    <!-- Row 1: Heading only — 20% top padding, 20% side margins to match content width -->
                    <tr>
                        <td style="padding:20% 20% 8px 20%;text-align:center;font-size:40px;font-weight:700;font-family:'Cinzel',serif;color:#1a0f08;line-height:1.2;word-wrap:break-word;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);">Session Date Updated</td>
                    </tr>

                    <!-- Row 2: Quest title + subtitle at top, spacer fills remaining space -->
                    <tr style="height:100%;">
                        <td style="padding:0 20%;vertical-align:top;height:100%;">
                            <table width="100%" border="0" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td style="font-size:26px;font-weight:700;font-family:'Cinzel',serif;color:#1a0f08;text-align:center;padding-top:8px;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);">@QuestTitle</td>
                                </tr>
                                <tr>
                                    <td style="font-size:15px;font-family:Georgia,serif;color:#1a0f08;text-align:center;padding-top:4px;font-style:italic;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);">The confirmed session date for @QuestTitle has changed.</td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Row 3: Gold Divider (same width as date info) -->
                    <tr>
                        <td style="padding:0 20%;"><hr style="border:none;border-top:1px solid #FFD700;margin:0;" /></td>
                    </tr>

                    <!-- Row 4: Date Info -->
                    <tr>
                        <td style="padding:8px 20%;">
                            <table width="100%" border="0" cellpadding="4" cellspacing="0">
                                <tr>
                                    <td style="font-size:14px;font-weight:700;font-family:Georgia,serif;color:#1a0f08;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);white-space:nowrap;width:45%;">Previous Date:</td>
                                    <td style="font-size:14px;font-family:Georgia,serif;color:#1a0f08;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);">@OldDate.ToString("dddd, MMMM d")</td>
                                </tr>
                                <tr>
                                    <td style="font-size:14px;font-weight:700;font-family:Georgia,serif;color:#1a0f08;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);white-space:nowrap;width:45%;">New Date:</td>
                                    <td style="font-size:14px;font-family:Georgia,serif;color:#1a0f08;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);">@NewDate.ToString("dddd, MMMM d")</td>
                                </tr>
                                <tr>
                                    <td style="font-size:14px;font-weight:700;font-family:Georgia,serif;color:#1a0f08;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);white-space:nowrap;width:45%;">Dungeon Master:</td>
                                    <td style="font-size:14px;font-family:Georgia,serif;color:#1a0f08;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);">@DmName</td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Row 5: CTA Button — 96px bottom padding to sit above poster bottom -->
                    <tr>
                        <td style="padding:16px 16px 96px 16px;text-align:center;">
                            <a href="@QuestUrl" style="background-color:#FFD700;color:#1a0f08;font-family:'Cinzel',serif;font-size:15px;font-weight:bold;padding:12px 24px;border-radius:6px;text-decoration:none;display:inline-block;border:2px solid #8B4513;text-align:center;">View Quest Details</a>
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>
</_EmailLayout>

@code {
    [Parameter, EditorRequired] public string QuestTitle { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string DmName { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string AppUrl { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string QuestUrl { get; set; } = string.Empty;
    [Parameter, EditorRequired] public DateTime OldDate { get; set; }
    [Parameter, EditorRequired] public DateTime NewDate { get; set; }
}
